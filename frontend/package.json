{
  "name": "ytalseg-relatorios",
  "version": "10.14.0",
  "private": true,
  "description": "YTALSEG Relatórios - Sistema Interno",
  "main": "electron/main.cjs",
  "author": "YTALSEG",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "vite build",
    "desktop": "npm run build && electron .",
    "dist": "npm run build && electron-builder --win nsis --publish never",
    "start": "electron .",
    "mobile": "vite --host 0.0.0.0 --port 5173",
    "dev-local": "vite --host 127.0.0.1 --port 5173"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "typescript": "latest",
    "vite": "6.4.2"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "br.com.ytalseg.erp",
    "productName": "YTALSEG Relatórios",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../app/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "YTALSEG Relatórios"
    }
  },
  "productName": "YTALSEG Relatórios"
}